# PostgreSQL Connection (Drizzle ORM)
# Local:   postgresql://postgres:password@localhost:5432/praveen_photography
# Neon:    postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/praveen_photography?sslmode=require
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/praveen_photography

# JWT Secret (change this to a long random string in production)
JWT_SECRET=praveen_photography_super_secret_key_change_in_production

# Next.js
NEXTAUTH_URL=http://localhost:3000

# ── Cloudinary ─────────────────────────────────────────────────────────────
# Get these from https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
